<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:2rem;">
  <div>
    <div class="text-mono text-xs text-muted mb-2">{{config.SITE_NAME}} · Error</div>
    <h1 style="font-family:var(--font-display);font-size:4rem;font-weight:300;color:var(--text);margin-bottom:1rem;">{{title}}</h1>
    <p class="text-muted" style="max-width:380px;margin:0 auto 2rem;">{{message}}</p>
    <a href="/" class="btn btn-ghost">← Go home</a>
  </div>
</div>
