<div class="dashboard container">
  <div class="dashboard-header fade-up">
    <h1 class="dashboard-greeting">Commit Review</h1>
    <p class="dashboard-meta">Review incoming code commit requests and accept them directly into the repository.</p>
  </div>

  {{#if message}}
  <div class="card fade-up delay-1" style="border:1px solid rgba(0,200,150,0.15);background:rgba(0,200,150,0.08);color:var(--biolum);padding:1rem;margin-bottom:1rem;">
    {{message}}
  </div>
  {{/if}}
  {{#if error}}
  <div class="card fade-up delay-1" style="border:1px solid rgba(255,80,80,0.18);background:rgba(255,80,80,0.08);color:#ff9aa3;padding:1rem;margin-bottom:1rem;">
    {{error}}
  </div>
  {{/if}}

  <div class="grid gap-1" style="grid-template-columns:1fr;">
    <div class="card fade-up delay-2">
      <div class="section-label" style="margin-bottom:1rem;">Create Commit Request</div>
      <form action="/tools/commit-review" method="POST" style="display:grid;gap:1rem;">
        <label class="text-sm text-muted">
          <div class="text-xs text-muted" style="margin-bottom:0.5rem;">Title</div>
          <input type="text" name="title" placeholder="Short summary of the change" required style="width:100%;padding:0.9rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface-2);color:var(--text);" />
        </label>

        <label class="text-sm text-muted">
          <div class="text-xs text-muted" style="margin-bottom:0.5rem;">Description</div>
          <textarea name="description" rows="3" placeholder="Describe the purpose of this commit" style="width:100%;padding:0.9rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface-2);color:var(--text);"></textarea>
        </label>

        <label class="text-sm text-muted">
          <div class="text-xs text-muted" style="margin-bottom:0.5rem;">Patch / diff</div>
          <textarea name="patch" rows="12" placeholder="Paste git diff or patch content here" required style="width:100%;padding:0.9rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface-2);color:var(--text);font-family:var(--font-mono);font-size:0.9rem;"></textarea>
        </label>

        <button type="submit" class="btn btn-primary" style="justify-content:center;">Create request</button>
      </form>
    </div>

    <div class="card fade-up delay-3">
      <div class="section-label" style="margin-bottom:1rem;">Pending Commit Requests</div>
      {{#if requests.length}}
      <div style="display:grid;gap:1rem;">
        {{#each requests}}
        <div style="border:1px solid var(--border);border-radius:var(--radius);padding:1rem;background:var(--surface-2);">
          <div style="display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;align-items:flex-start;">
            <div>
              <div style="font-weight:700;color:var(--text);">{{this.title}}</div>
              <div class="text-xs text-muted" style="margin-top:0.35rem;">Created by: {{this.creator_name}} · {{formatDate this.created_at}}</div>
            </div>
            <span style="font-size:0.75rem;padding:0.3rem 0.6rem;border-radius:999px;background:{{#if (eq this.status 'pending')}}rgba(255,218,94,0.14){{else if (eq this.status 'accepted')}}rgba(0,200,150,0.14){{else if (eq this.status 'rejected')}}rgba(255,80,80,0.14){{else}}rgba(255,255,255,0.06){{/if}};color:var(--text);font-family:var(--font-mono);">
              {{this.status}}
            </span>
          </div>
          {{#if this.description}}
          <div class="text-sm text-muted" style="margin:0.75rem 0;">{{this.description}}</div>
          {{/if}}
          <details style="margin-bottom:0.75rem;">
            <summary style="cursor:pointer;color:var(--accent);">View patch</summary>
            <pre style="margin-top:0.75rem;padding:0.9rem;border-radius:var(--radius);background:rgba(255,255,255,0.03);overflow:auto;font-family:var(--font-mono);font-size:0.82rem;">{{this.patch}}</pre>
          </details>
          {{#if (eq this.status 'pending')}}
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <form action="/tools/commit-review/{{this.id}}/accept" method="POST" style="margin:0;">
              <button type="submit" class="btn btn-success">Accept</button>
            </form>
            <form action="/tools/commit-review/{{this.id}}/reject" method="POST" style="margin:0;">
              <button type="submit" class="btn btn-danger">Reject</button>
            </form>
          </div>
          {{else}}
          <div class="text-xs text-muted">Processed by {{this.actor_name}} on {{formatDate this.acted_at}} · {{this.action_detail}}</div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="text-sm text-muted">No commit requests yet. Create the first request with a git diff or patch and approve it from this panel.</p>
      {{/if}}
    </div>
  </div>
</div>
