# ============================================================
#  ROOT — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ============================================================

# Server
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000

# Session (generate a strong random string)
SESSION_SECRET=replace-with-a-strong-random-secret-key

# Database path (relative to project root)
DB_PATH=./db/root.sqlite

# Google OAuth 2.0
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Access Control
# Comma-separated list of allowed email addresses
# Leave empty to allow any Google account
ALLOWED_EMAILS=your@email.com
